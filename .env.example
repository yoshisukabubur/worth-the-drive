# Copy to ".env" locally (never commit ".env").
# On Render: set these in Environment (Dashboard).

PORT=8000

# RapidAPI — Gas Price
RAPIDAPI_KEY=
RAPIDAPI_HOST=gas-price.p.rapidapi.com
ALL_USA_PRICE_URL=https://gas-price.p.rapidapi.com/allUsaPrice

# Optional: state-by-state endpoint pattern (if you use it)
# STATE_PRICES_URL=
# STATE_PRICES_PARAM_NAME=state

# Google Maps (Maps JavaScript API) — restrict key by HTTP referrer in Cloud Console
GOOGLE_MAPS_API_KEY=

# US station pins: OpenStreetMap Overpass (set 0 to use illustrative mock only)
USE_OSM_STATIONS=1

# OSM: only keep points with brand/operator or a known US chain in name (set 0 for all OSM fuel)
OSM_BRAND_FILTER=1

# CORS: your public site origin(s), comma-separated, no trailing slash
# Example: https://worth-the-drive.onrender.com
ALLOWED_ORIGINS=

# Optional: protect /api/* (not /api/public/*) with header x-app-api-key
APP_API_KEY=

RATE_LIMIT_PER_MINUTE=60
RECOMMEND_RATE_LIMIT_PER_MINUTE=20
FREE_DAILY_LIMIT=20
CACHE_TTL_SECONDS=300

# Optional donation links (shown on /about)
DONATION_PAYPAL_URL=
DONATION_COFFEE_URL=
